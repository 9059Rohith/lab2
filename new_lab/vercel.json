{
  "version": 2,
  "public": false,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install --prefix ./backend && npm install --prefix ./frontend",
  "env": {
    "MONGODB_URI": "",
    "CORS_ORIGINS": "https://yourdomain.vercel.app,http://localhost:5173",
    "PORT": "3000"
  },
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs18.x",
      "memory": 1024
    }
  },
  "redirects": [
    {
      "source": "/api/:path*",
      "destination": "/backend/server.js"
    }
  ]
}
