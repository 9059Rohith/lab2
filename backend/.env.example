# Environment Variables for Star Math Explorer Backend

# MongoDB Connection
# Get your MongoDB URI from MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/autism-space-learn?retryWrites=true&w=majority

# Server Port
PORT=3000

# Environment Mode (development, production, test)
NODE_ENV=development

# Optional: JWT Secret (if you add authentication later)
# JWT_SECRET=your_secret_key_here

# Optional: API Keys (if you add external services)
# API_KEY=your_api_key_here
